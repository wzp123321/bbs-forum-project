# =============================================================
#  环境变量样例 (复制为 .env 后按需修改)
# =============================================================

# MySQL root 密码 (生产请务必修改)
MYSQL_ROOT_PASSWORD=123456

# 数据库名
MYSQL_DATABASE=bbs

# MySQL 宿主机端口
MYSQL_PORT=3306

# 前端宿主机端口
WEB_PORT=80

# JWT 密钥, 至少 32 字节, 生产请用 openssl rand -base64 32 生成
BBS_JWT_SECRET=please-change-me-in-prod-32bytes-min
